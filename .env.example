# Supabase / Postgres
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# Cron job protection secret
CRON_SECRET="your-random-secret-here"

# Judge.me OAuth credentials (from Judge.me partner dashboard)
JUDGEME_CLIENT_ID="your-judgeme-client-id"
JUDGEME_CLIENT_SECRET="your-judgeme-client-secret"
JUDGEME_REDIRECT_URI="https://your-app.vercel.app/api/oauth/callback"

# App URL
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
